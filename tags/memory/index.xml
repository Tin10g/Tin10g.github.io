    </item>
    <item>
      <title>论文 · Hopfield-Fenchel-Young Networks: A Unified Framework for Associative Memory Retrieval</title>
      <link>http://localhost:1313/posts/%E8%AE%BA%E6%96%87%E9%98%85%E8%AF%BB-hopfield-fenchel-young-networks-a-unified-framework-for-associative-memory-retrieval/</link>
      <pubDate>Wed, 01 Jul 2026 11:25:40 +0800</pubDate><author>ting10win@gmail.com (Ting)</author>
      <guid>http://localhost:1313/posts/%E8%AE%BA%E6%96%87%E9%98%85%E8%AF%BB-hopfield-fenchel-young-networks-a-unified-framework-for-associative-memory-retrieval/</guid>
