    </item>
    <item>
      <title>论文 · Generative Agents: Interactive Simulacra of Human Behavior</title>
      <link>http://localhost:1313/posts/%E8%AE%BA%E6%96%87%E9%98%85%E8%AF%BB-generative-agentsinteractive-simulacra-of-human-behavior/</link>
